<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SzerszamkolcsonzoMaui.ViewModels"
             x:Class="SzerszamkolcsonzoMaui.Pages.LoginPage"
             Title=""
             BackgroundColor="#F5F1E8">

    <ScrollView>
        <VerticalStackLayout
            Spacing="16"
            Padding="32,60,32,32"
            VerticalOptions="Center">

            <!-- Logo -->
            <Label Text="🔧"
                   FontSize="56"
                   HorizontalOptions="Center"
                   Margin="0,0,0,4"/>

            <Label Text="Szerszámkölcsönző"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#3D2F1F"/>

            <Label Text="Admin vezérlőpanel"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="#6B5D4F"
                   Margin="0,0,0,24"/>

            <!-- Email -->
            <Border Stroke="#E8DCC8" StrokeThickness="1" StrokeShape="RoundRectangle 8"
                    BackgroundColor="White" Padding="4,0">
                <Entry Placeholder="Email cím"
                       Keyboard="Email"
                       Text="{Binding Email}"
                       BackgroundColor="Transparent"
                       FontSize="15"/>
            </Border>

            <!-- Jelszó -->
            <Border Stroke="#E8DCC8" StrokeThickness="1" StrokeShape="RoundRectangle 8"
                    BackgroundColor="White" Padding="4,0">
                <Entry Placeholder="Jelszó"
                       IsPassword="True"
                       Text="{Binding Password}"
                       BackgroundColor="Transparent"
                       FontSize="15"/>
            </Border>

            <!-- Emlékezzen rám -->
            <HorizontalStackLayout Spacing="8">
                <CheckBox IsChecked="{Binding RememberMe}"
                          Color="#2196F3"/>
                <Label Text="Emlékezzen rám"
                       VerticalOptions="Center"
                       TextColor="#3D2F1F"
                       FontSize="14"/>
            </HorizontalStackLayout>

            <!-- Hibaüzenet -->
            <Border IsVisible="{Binding HasError}"
                    BackgroundColor="#FFEBEE"
                    Stroke="#F44336"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 6"
                    Padding="12,10">
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#C62828"
                       FontSize="13"/>
            </Border>

            <!-- Bejelentkezés gomb -->
            <Button Text="{Binding ButtonText}"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsNotLoading}"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    HeightRequest="52"
                    Margin="0,8,0,0"/>

            <!-- Betöltés jelző -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="#2196F3"
                               HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
