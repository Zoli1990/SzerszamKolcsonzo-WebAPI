<Window x:Class="WpfSzerszamKolcsonzo.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bejelentkezés – Szerszámkölcsönző Admin"
        Height="485" Width="456"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F1E8">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Cím -->
        <TextBlock Grid.Row="0" Text="🔧 Admin bejelentkezés"
                   FontSize="18" FontWeight="Bold"
                   Foreground="#3D2F1F"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,24"/>

        <!-- Email -->
        <TextBlock Grid.Row="1" Text="Email" Foreground="#3D2F1F" Margin="0,0,0,4"/>
        <TextBox Grid.Row="2" x:Name="EmailBox"
                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                 Padding="8,6" Margin="0,0,0,12"
                 BorderBrush="#C0A882" BorderThickness="1"
                 Background="White"/>

        <!-- Jelszó -->
        <TextBlock Grid.Row="3" Text="Jelszó" Foreground="#3D2F1F" Margin="0,0,0,4"/>
        <PasswordBox Grid.Row="4" x:Name="PasswordBox"
                     Padding="8,6" Margin="0,0,0,20"
                     BorderBrush="#C0A882" BorderThickness="1"
                     Background="White"/>

        <!-- Emlékezz rám -->
        <CheckBox Grid.Row="5"
                  Content="Emlékezz rám"
                  IsChecked="{Binding RememberMe}"
                  Foreground="#3D2F1F"
                  Margin="0,0,0,16"/>

        <!-- Gomb + hibaüzenet -->
        <StackPanel Grid.Row="6">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#F44336"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>

            <Button Content="{Binding ButtonText}"
                    Command="{Binding LoginCommand}"
                    CommandParameter="{Binding ElementName=PasswordBox}"
                    IsEnabled="{Binding IsNotLoading}"
                    Background="#2196F3" Foreground="White"
                    FontWeight="Bold" FontSize="14"
                    Padding="0,10" BorderThickness="0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
